<% if profile.errors.any? %>
  <div class="bg-red-50 border border-red-200 rounded-lg p-4 mb-4">
    <p class="text-sm font-medium text-red-800 mb-2">
      <%= pluralize(profile.errors.count, "error") %> prevented your profile from being saved:
    </p>
    <ul class="list-disc list-inside space-y-1">
      <% profile.errors.each do |error| %>
        <li class="text-sm text-red-700"><%= error.full_message %></li>
      <% end %>
    </ul>
  </div>
<% end %>
