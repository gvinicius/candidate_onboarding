<% if errors.any? %>
  <div class="bg-red-50 border border-red-200 rounded-lg p-3">
    <p class="text-xs font-medium text-red-800 mb-1">Please fix the following:</p>
    <ul class="list-disc list-inside space-y-0.5">
      <% errors.each do |error| %>
        <li class="text-xs text-red-700"><%= error.full_message %></li>
      <% end %>
    </ul>
  </div>
<% end %>
