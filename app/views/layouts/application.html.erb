<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= content_for(:title) || "Candidate Onboarding" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <link rel="icon" href="/icon.png" type="image/png">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-slate-50 min-h-screen text-slate-900 antialiased">
    <!-- Top navbar -->
    <header class="sticky top-0 z-40 w-full border-b border-slate-200 bg-white/95 backdrop-blur">
      <div class="max-w-7xl mx-auto px-4 flex h-14 items-center justify-between">
        <!-- Logo + nav links -->
        <div class="flex items-center gap-6">
          <%= link_to root_path, class: "flex items-center gap-2 font-semibold text-slate-900 text-sm" do %>
            <div class="w-7 h-7 bg-slate-900 rounded-md flex items-center justify-center">
              <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
            </div>
            Candidate Onboarding
          <% end %>

          <nav class="flex items-center gap-1">
            <%= link_to "Home", root_path,
                  class: "px-3 py-1.5 rounded-md text-sm transition-colors #{current_page?(root_path) ? "bg-slate-100 text-slate-900 font-medium" : "text-slate-600 hover:text-slate-900 hover:bg-slate-50"}" %>
            <%= link_to "Candidates", candidate_profiles_path,
                  class: "px-3 py-1.5 rounded-md text-sm transition-colors #{current_page?(candidate_profiles_path) || request.path.start_with?("/candidate_profiles") ? "bg-slate-100 text-slate-900 font-medium" : "text-slate-600 hover:text-slate-900 hover:bg-slate-50"}" %>
          </nav>
        </div>

      </div>
    </header>

    <!-- Flash messages -->
    <% if notice %>
      <div id="flash-notice" class="fixed top-16 right-4 z-50 bg-green-50 border border-green-200 text-green-800 px-4 py-3 rounded-lg shadow-sm text-sm">
        <%= notice %>
      </div>
    <% end %>
    <% if alert %>
      <div id="flash-alert" class="fixed top-16 right-4 z-50 bg-red-50 border border-red-200 text-red-800 px-4 py-3 rounded-lg shadow-sm text-sm">
        <%= alert %>
      </div>
    <% end %>

    <main class="min-h-[calc(100vh-3.5rem)]">
      <%= yield %>
    </main>
  </body>
</html>
