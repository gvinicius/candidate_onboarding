<div class="border border-slate-100 rounded-lg p-4 mb-3 relative" data-nested-form-target="item">
  <%= f.hidden_field :id %>
  <%= f.hidden_field :_destroy, class: "destroy-field" %>

  <button type="button"
          class="absolute top-3 right-3 text-slate-400 hover:text-red-500 transition-colors"
          data-action="click->nested-form#remove">
    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
    </svg>
  </button>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
    <div class="field-group">
      <%= f.label :job_title, "Job title *", class: "form-label" %>
      <%= f.text_field :job_title, class: "form-input", placeholder: "Dental Hygienist", required: true, autocomplete: "organization-title" %>
    </div>
    <div class="field-group">
      <%= f.label :company_name, "Company name *", class: "form-label" %>
      <%= f.text_field :company_name, class: "form-input", placeholder: "Tandartspraktijk X", required: true, autocomplete: "organization" %>
    </div>
    <div class="field-group">
      <%= f.label :start_date, "Start date", class: "form-label" %>
      <%= f.date_field :start_date, class: "form-input" %>
    </div>
    <div class="field-group">
      <%= f.label :end_date, "End date", class: "form-label" %>
      <%= f.date_field :end_date, class: "form-input", disabled: f.object.current_job %>
    </div>
    <div class="field-group sm:col-span-2">
      <label class="inline-flex items-center gap-2 cursor-pointer">
        <%= f.check_box :current_job, class: "h-3.5 w-3.5 rounded border-slate-300", data: { action: "change->nested-form#toggleEndDate" } %>
        <span class="text-sm text-slate-700 font-medium">This is my current job</span>
      </label>
    </div>
    <div class="field-group sm:col-span-2">
      <%= f.label :responsibilities, "Responsibilities", class: "form-label" %>
      <%= f.text_area :responsibilities, class: "form-textarea", placeholder: "Describe your main responsibilities..." %>
    </div>
  </div>
</div>
